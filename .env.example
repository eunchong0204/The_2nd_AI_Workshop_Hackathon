# Copy this file to `.env` and fill in your keys. `.env` is git-ignored; never
# commit real keys. utils/config.py loads it automatically via python-dotenv.

# ---------------------------------------------------------------------------
# LLM provider. Every step uses whatever is set here, so the SAME model runs
# across the whole pipeline.
#   ollama -> local open-source model
#   openai -> an OpenAI frontier model
# ---------------------------------------------------------------------------
LLM_PROVIDER=openai
#LLM_PROVIDER=ollama

# Override the model per provider if you want. Defaults live in utils/config.py:
#   ollama -> llama3.1:8b
#   openai -> gpt-4o-mini
LLM_MODEL=gpt-4.1
# LLM_MODEL=llama3.1:8b

# API key: required for openai (chat) AND for the Step 4 embeddings, which ALWAYS
# go to OpenAI -- so this is needed even when LLM_PROVIDER=ollama.
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# OpenFDA drug label API key. Get a free one at https://open.fda.gov/apis/authentication/
# Without a key you're capped at 240 requests/day; with one, 240/min.
# ---------------------------------------------------------------------------
OPENFDA_API_KEY=
